<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 animate__animated animate__fadeInLeft">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-box-arrow-in-right display-3 text-primary"></i>
                        <h2 class="fw-bold mt-2">Welcome Back</h2>
                        <p class="text-secondary">Sign in to your account</p>
                    </div>
                    <form  data-controller="login" data-action="submit->register#submit" action="/login" method="POST">
                        <div class="mb-3">
                            <label class="form-label" for="email">Email</label>
                            <input type="email" class="form-control form-control-lg" placeholder="name@example.com" id="email" data-target="login.email"
                                required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" for="password">Password</label>
                            <input type="password" class="form-control form-control-lg" placeholder="******" id="password" data-target="login.password" required>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="remember">
                                <label class="form-check-label" for="remember">Remember me</label>
                            </div>
                            <a href="#" class="text-decoration-none">Forgot password?</a>
                        </div>
                        <div class="alert alert-danger d-none" data-target="login.loginError" id="loginError"></div>
                        <button type="submit" data-action="click->login#submit" class="btn btn-primary btn-lg w-100 rounded-pill">Login <i
                                class="bi bi-arrow-right-short"></i></button>
                    </form>
                    <div class="text-center mt-4">
                        <span>New to StudyHub? <a href="/register" class="fw-bold">Register now</a></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>